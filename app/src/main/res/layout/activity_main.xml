<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Grade de quadrantes (fundo) -->
    <LinearLayout
        android:id="@+id/quadrant_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Linha superior: Fazer Agora | Agendar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/quadrant_fazer_agora"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#FFCDD2">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Fazer Agora"
                    android:textColor="#37474F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#FFFFFF" />

            <FrameLayout
                android:id="@+id/quadrant_agendar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#C8E6C9">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Agendar"
                    android:textColor="#37474F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </FrameLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FFFFFF" />

        <!-- Linha inferior: Delegar | Eliminar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/quadrant_delegar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#FFF9C4">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Delegar"
                    android:textColor="#37474F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#FFFFFF" />

            <FrameLayout
                android:id="@+id/quadrant_eliminar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#BBDEFB">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Descartar/Avaliar"
                    android:textColor="#37474F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Container das bolhas (overlay transparente) -->
    <FrameLayout
        android:id="@+id/bubble_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Zona de exclusão (aparece durante o arraste) -->
    <TextView
        android:id="@+id/delete_zone"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:background="@drawable/bg_delete_zone"
        android:elevation="12dp"
        android:visibility="gone" />

    <!-- Barra de input flutuante -->
    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input_bar"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <EditText
            android:id="@+id/edit_task"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Nova tarefa…"
            android:textColorHint="#9E9E9E"
            android:textColor="#212121"
            android:inputType="textCapSentences"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:textSize="15sp"
            android:paddingStart="4dp" />

        <Button
            android:id="@+id/btn_add"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:backgroundTint="#FF5252"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="0dp" />
    </LinearLayout>

</FrameLayout>
